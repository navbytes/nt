# Wails build output (the compiled .app / .exe / binaries)
/build/bin/

# Wails-generated JS runtime bindings (recreated by `wails build`)
/frontend/wailsjs/

# The compiled spike binary from `make desktop-build`
/nt-desktop
nt

# A bare `go build` in this module emits a binary named after the dir (~16MB)
/desktop
